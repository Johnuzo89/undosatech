# ============================================================
# .env.node.example — copy to .env.node and fill in your values
# Contact research@undosatech.com for REGISTRATION_SECRET
# ============================================================

# ── Required ─────────────────────────────────────────────────────────────────

# Unique identifier for your node (lowercase, hyphens only, no spaces)
# Example: nhs-kings-001, uob-cardiff-node1
NODE_ID=your-institution-node-001

# Your institution's full name
INSTITUTION_NAME=Your Institution Name

# Your institution's email domain
INSTITUTION_DOMAIN=yourinstitution.ac.uk

# Contact email for this node
CONTACT_EMAIL=research-it@yourinstitution.ac.uk

# Institutional authoriser — activation requires confirmation from a named
# PI, data custodian, or IT/security contact at your institution. They receive
# an email with a confirmation link; the node stays pending until they confirm
# and UndosaTech approves. Must be a different person from CONTACT_EMAIL, at
# the same email domain as INSTITUTION_DOMAIN.
AUTHORISER_NAME=Dr Jane Example
AUTHORISER_ROLE=data_custodian   # pi | data_custodian | it_security
AUTHORISER_EMAIL=j.example@yourinstitution.ac.uk

# The PUBLIC IP or hostname of this server that Railway can reach
# If behind NAT: set up port forwarding for NODE_PORT, put your external IP here
# Or use ngrok/Tailscale for secure tunnelling
NODE_PUBLIC_HOST=203.0.113.10

# Port to listen on (must match your firewall/port-forward settings)
NODE_PORT=8080

# Registration secret — provided by UndosaTech team (keep this private!)
REGISTRATION_SECRET=REPLACE_WITH_SECRET_FROM_UNDOSATECH

# ── Optional ─────────────────────────────────────────────────────────────────

# Path to your local training data on the HOST machine
LOCAL_DATA_PATH=/opt/medical-data/training

# Does this server have a GPU?
GPU_AVAILABLE=false

# Max samples to contribute per federated study
MAX_SAMPLES=10000

# Models your institution is willing to run (comma-separated)
# Options: ResNet-18, ResNet-50, ResNet-101, EfficientNet-B0, EfficientNet-B4, ViT-B/16, Lightweight CNN
SUPPORTED_MODELS=ResNet-18,EfficientNet-B0,Lightweight CNN

# Tags describing your data specialisation (comma-separated)
# Examples: ophthalmology, radiology, pathology, cardiology, dermatology, general
TAGS=general

# Orchestrator URL (don't change unless you're running a private instance)
ORCHESTRATOR_URL=https://undosatech-production.up.railway.app
